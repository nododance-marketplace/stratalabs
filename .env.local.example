# ─── Stripe ───────────────────────────────────────────────────────────────
# Copy this file to ".env.local" and fill in your keys.
# NEVER commit real keys — .env.local is gitignored.
# Get your keys at https://dashboard.stripe.com/apikeys (use TEST keys first).

# Secret key (server-side only). sk_test_... in test mode, sk_live_... when live.
STRIPE_SECRET_KEY=

# Webhook signing secret for /api/stripe/webhook. Starts with whsec_
# Optional for launch. From Dashboard → Developers → Webhooks, or the Stripe CLI.
STRIPE_WEBHOOK_SECRET=

# Public base URL of the site (absolute image URLs + checkout redirects).
# Local: http://localhost:3030   Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=
